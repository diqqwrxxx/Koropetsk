#include <iostream>
#include <vector>

using namespace std;

template <typename T>
class Stack {
private:
    struct Node {
        T data;
        Node* next;
    };
    Node* topNode;

public:
    Stack() : topNode(nullptr) {}

    ~Stack() {
        while (!isEmpty()) {
            pop();
        }
    }

    bool isEmpty() {
        return topNode == nullptr;
    }

    void push(T value) {
        Node* newNode = new Node;
        newNode->data = value;
        newNode->next = topNode;
        topNode = newNode;
    }

    void pop() {
        if (isEmpty()) return;
        Node* temp = topNode;
        topNode = topNode->next;
        delete temp;
    }

    T top() {
        if (!isEmpty()) {
            return topNode->data;
        }
        return T();
    }

    void printAndClear() {
        while (!isEmpty()) {
            cout << top() << " ";
            pop();
        }
        cout << endl;
    }
};

int main() {
    setlocale(LC_ALL, "Ukrainian");

    Stack<int> intStack;
    Stack<double> doubleStack;
    int n;

    cout << "Скільки цілих чисел ввести? ";
    cin >> n;
    cout << "Введіть цілі числа: ";
    for (int i = 0; i < n; i++) {
        int val;
        cin >> val;
        intStack.push(val);
    }

    cout << "Скільки дійсних чисел ввести? ";
    cin >> n;
    cout << "Введіть дійсні числа: ";
    for (int i = 0; i < n; i++) {
        double val;
        cin >> val;
        doubleStack.push(val);
    }

    cout << "\nЦілі числа (зворотний порядок): ";
    intStack.printAndClear();

    cout << "Дійсні числа (зворотний порядок): ";
    doubleStack.printAndClear();

    return 0;
}
