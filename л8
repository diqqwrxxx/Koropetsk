#include <iostream>
#include <ctype.h>

using namespace std;

int main() {
    int ch;
    bool inNumber = false;

    while ((ch = cin.get()) != EOF) {
        if (isdigit(ch)) {
            inNumber = true;
        } else {
            if (inNumber) {
                inNumber = false;
            }
            cout.put(ch);
        }
    }

    return 0;
}
