#include <iostream>
#include <string>

using namespace std;

int main() {
    string s;
    cout << "Введіть рядок: ";
    getline(cin, s);

    int round = 0, square = 0;

    for (char c : s) {
        if (c == '(') round++;
        if (c == ')') round--;
        if (c == '[') square++;
        if (c == ']') square--;
        
        if (round < 0 || square < 0) break;
    }

    if (round == 0 && square == 0) {
        cout << "Кількість дужок співпадає" << endl;
    } else {
        cout << "Кількість дужок не співпадає або порушено порядок" << endl;
    }

    return 0;
}
